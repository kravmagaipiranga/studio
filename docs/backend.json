{
  "entities": {
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student in the Krav Magá IPIRANGA school.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "belt": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo", "Pendente"] }
      },
      "required": ["id", "name", "email", "phone", "registrationDate"]
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "planType": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["id", "studentId", "paymentDate", "amount"]
    },
    "GiftCardOrder": {
      "title": "GiftCardOrder",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerName": { "type": "string" },
        "buyerEmail": { "type": "string" },
        "recipientName": { "type": "string" },
        "status": { "type": "string" },
        "validationCode": { "type": "string" }
      },
      "required": ["id", "buyerName", "buyerEmail", "recipientName", "status", "validationCode"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": { "$ref": "#/backend/entities/Student" },
          "description": "Stores student data."
        }
      },
      {
        "path": "/payments/{paymentId}",
        "definition": {
          "entityName": "Payment",
          "schema": { "$ref": "#/backend/entities/Payment" },
          "description": "Stores individual payment transactions."
        }
      },
      {
        "path": "/giftCardOrders/{orderId}",
        "definition": {
          "entityName": "GiftCardOrder",
          "schema": { "$ref": "#/backend/entities/GiftCardOrder" },
          "description": "Stores gift card orders."
        }
      }
    ]
  }
}