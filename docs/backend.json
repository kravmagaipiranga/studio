
{
  "entities": {
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student in the Krav Magá IPIRANGA school.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Student entity."
        },
        "userId": {
          "type": "string",
          "description": "The Firebase Auth User ID associated with this student for login."
        },
        "name": {
          "type": "string",
          "description": "The full name of the student."
        },
        "email": {
          "type": "string",
          "description": "The email address of the student.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the student."
        },
        "registrationDate": {
          "type": "string",
          "description": "The date the student registered.",
          "format": "date-time"
        },
        "planId": {
          "type": "string",
          "description": "Reference to Plan. (Relationship: Plan 1:N Student)"
        },
        "address": {
          "type": "string",
          "description": "The student's address."
        },
        "readyForReview": {
          "type": "boolean",
          "description": "Indicates if the student is ready for a belt review."
        },
        "paymentCredits": {
            "type": "string",
            "description": "Stores the amount of credit a student has, as a string."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "phone",
        "registrationDate"
      ]
    },
    "GiftCardOrder": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GiftCardOrder",
      "type": "object",
      "description": "Represents a gift card purchase order.",
      "properties": {
        "id": { "type": "string" },
        "buyerName": { "type": "string" },
        "buyerEmail": { "type": "string", "format": "email" },
        "buyerPhone": { "type": "string" },
        "buyerCpf": { "type": "string" },
        "recipientName": { "type": "string" },
        "message": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["Pix", "Boleto"] },
        "status": { "type": "string", "enum": ["Pendente", "Pago"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalValue": { "type": "number" },
        "validationCode": { "type": "string" }
      },
      "required": ["id", "buyerName", "buyerEmail", "buyerPhone", "buyerCpf", "recipientName", "paymentMethod", "status", "createdAt", "validationCode"]
    },
    "WomensMonthLead": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WomensMonthLead",
      "type": "object",
      "description": "Represents an interested person for the March Women's Month campaign.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "chosenClass": { "type": "string" },
        "year": { "type": "number" },
        "attended": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "whatsapp", "chosenClass", "year", "attended", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": {
            "$ref": "#/backend/entities/Student"
          },
          "description": "Stores student data."
        }
      },
      {
        "path": "/giftCardOrders/{orderId}",
        "definition": {
          "entityName": "GiftCardOrder",
          "schema": {
            "$ref": "#/backend/entities/GiftCardOrder"
          },
          "description": "Stores gift card purchase orders."
        }
      },
      {
        "path": "/womensMonth/{leadId}",
        "definition": {
          "entityName": "WomensMonthLead",
          "schema": {
            "$ref": "#/backend/entities/WomensMonthLead"
          },
          "description": "Stores leads for the Women's Month campaign."
        }
      }
    ]
  }
}
