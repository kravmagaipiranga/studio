rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: This ruleset implements a Role-Based Access Control (RBAC) model
     * with two primary roles: "Admin" and "Student" (implied as any authenticated user).
     * Admins possess comprehensive read and write permissions across the database.
     * Authenticated users are generally restricted to reading public data or their own data.
     *
     * Key Security Decisions:
     * - Admin Access: A user is an Admin if their UID exists as a document in the `/roles_admin`
     *   collection AND that document contains the field `isAdmin: true`.
     *   This is a secure and explicit way to manage administrative privileges.
     * - Default Deny: All operations are denied by default.
     * - Production Security: Listing all students is restricted to Admins to prevent data leaks.
     *   Write operations on critical data are also restricted to Admins.
     */

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // A user is an admin if their UID is a document in 'roles_admin'
    // and that document has a field 'isAdmin' set to true.
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true;
    }

    function newDocStudentIdMatchesPath(studentId) {
      return request.resource.data.studentId == studentId;
    }

    function studentIdIsImmutable() {
      return request.resource.data.studentId == resource.data.studentId;
    }


    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    match /students/{studentId} {
      // Admins can get any student. Students can only get their own profile.
      allow get: if isOwner(studentId) || isAdmin();
      
      // Listing all students is a sensitive operation, restricted to Admins.
      allow list: if isAdmin();

      // Admins can create students. A user can create their own profile.
      allow create: if (isOwner(studentId) && request.resource.data.id == studentId) || isAdmin();
      
      // Only Admins can update student profiles.
      allow update: if isAdmin();
      
      // Only Admins can delete students.
      allow delete: if isAdmin();

      match /payments/{paymentId} {
        allow get: if isOwner(studentId) || isAdmin();
        allow list: if isOwner(studentId) || isAdmin();
        allow create: if isAdmin() && newDocStudentIdMatchesPath(studentId);
        allow update: if isAdmin() && studentIdIsImmutable();
        allow delete: if isAdmin();
      }

      match /exams/{examId} {
        allow get: if isOwner(studentId) || isAdmin();
        allow list: if isOwner(studentId) || isAdmin();
        allow create: if isAdmin() && newDocStudentIdMatchesPath(studentId);
        allow update: if isAdmin() && studentIdIsImmutable();
        allow delete: if isAdmin();
      }
    }
    
    // Other top-level collections like appointments, sales, etc., should be
    // admin-only for writes, and potentially reads depending on the data.
    match /appointments/{docId} {
      allow read, write: if isAdmin();
    }
    match /privateClasses/{docId} {
      allow read, write: if isAdmin();
    }
     match /seminars/{docId} {
      allow read, write: if isAdmin();
    }
     match /sales/{docId} {
      allow read, write: if isAdmin();
    }
    
    match /plans/{planId} {
      // Plans are public to read.
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      // Only admins can manage plans.
      allow create, update, delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      // Only Admins can manage other admins.
      allow read, write: if isAdmin();
    }
  }
}
