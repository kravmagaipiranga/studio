rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrador: custom claim 'admin: true' OU e-mail verificado (fallback).
    // ATENÇÃO: migrar para custom claim exclusivo assim que estiver configurado.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email_verified == true
      );
    }

    // Verifica se o documento pertence ao aluno autenticado via studentId
    function isOwnerViaStudentId(studentId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/students/$(studentId)).data.userId == request.auth.uid;
    }

    // ─── REGRA CORINGA ────────────────────────────────────────────────────────
    // Administradores têm acesso total a qualquer coleção não coberta abaixo.
    // As regras específicas abaixo têm precedência (OR lógico no Firestore).
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── ALUNOS ───────────────────────────────────────────────────────────────
    match /students/{studentId} {
      // Formulários públicos de captação podem criar alunos sem autenticação
      allow create: if true;
      // Aluno lê e edita apenas o seu próprio documento; admin acessa todos
      allow read:   if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ─── PAGAMENTOS ───────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:  if isAdmin() || isOwnerViaStudentId(resource.data.studentId);
      allow write: if isAdmin();
    }

    // ─── PRESENÇAS ────────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      allow read:  if isAdmin() || isOwnerViaStudentId(resource.data.studentId);
      allow write: if isAdmin();
    }

    // ─── EXAMES ───────────────────────────────────────────────────────────────
    match /exams/{examId} {
      allow read:  if isAdmin() || isOwnerViaStudentId(resource.data.studentId);
      allow write: if isAdmin();
    }

    // ─── SEMINÁRIOS ───────────────────────────────────────────────────────────
    match /seminars/{seminarId} {
      allow read:  if isAdmin() || isOwnerViaStudentId(resource.data.studentId);
      allow write: if isAdmin();
    }

    // ─── APOSTILA (Currículo) ─────────────────────────────────────────────────
    // Qualquer aluno autenticado pode ler — necessário para a aba Currículo
    match /handbook/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── FORMULÁRIOS PÚBLICOS ─────────────────────────────────────────────────
    match /womensMonth/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /giftCardOrders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

  }
}
