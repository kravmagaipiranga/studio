
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Regras para acesso administrativo (exige login)
    // Permite leitura e escrita em qualquer documento se o usuário estiver logado
    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    // Regras para acessos públicos (não exige login)
    // Necessário para formulários externos de captação
    
    match /students/{studentId} {
      allow create: if true; 
    }
    
    match /womensMonth/{leadId} {
      allow create: if true;
    }

    match /giftCardOrders/{orderId} {
      allow create: if true;
    }
  }
}
