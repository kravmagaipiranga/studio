
# -----------------------------------------------------------------------------
# Firebase Client SDK Configuration
#
# These variables are used by the Firebase Client SDK to connect to your
# Firebase project. They are safe to be exposed to the client.
# You can find these values in your Firebase project settings.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"

# -----------------------------------------------------------------------------
# Firebase Admin SDK Configuration (for server-side operations) & Google APIs
#
# These variables are used by the Firebase Admin SDK and Google APIs on the server.
# IMPORTANT: These are sensitive credentials and MUST NOT be exposed to the client.
# Keep them in .env.local and do not commit this file to version control.
#
# Instructions:
# 1. Go to your Firebase Project Settings -> Service accounts.
# 2. Click "Generate new private key" to download a JSON file.
# 3. Open the JSON file and copy the values for:
#    - GCLOUD_PROJECT: "project_id" from the JSON file.
#    - GOOGLE_CLIENT_EMAIL: "client_email" from the JSON file.
#    - GOOGLE_PRIVATE_KEY: "private_key" from the JSON file. IMPORTANT: When pasting,
#      replace all newline characters (\n) with the literal string "\\n".
#
# 4. For Google Sheets:
#    - Enable the Google Sheets API in your Google Cloud Console.
#    - Create a new Google Sheet.
#    - Share the sheet with the "client_email" from your service account, giving it "Editor" permissions.
#    - GOOGLE_SHEET_ID: The ID from your Google Sheet URL (e.g., .../spreadsheets/d/THIS_IS_THE_ID/edit).
#
# 5. For the Backup API:
#    - BACKUP_API_SECRET_KEY: Generate a strong, random string. This will be used as a simple
#      password to authorize daily backup requests from an external scheduler.
# -----------------------------------------------------------------------------
GCLOUD_PROJECT="your-project-id"
GOOGLE_CLIENT_EMAIL="your-service-account-email@your-project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY_CONTENT_HERE\\n-----END PRIVATE KEY-----\\n"
GOOGLE_SHEET_ID="your-google-sheet-id"
BACKUP_API_SECRET_KEY="generate-a-strong-random-secret-key"

# -----------------------------------------------------------------------------
# Genkit (Gemini API)
#
# Used for generative AI features.
# You can get this from Google AI Studio.
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key"
